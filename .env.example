# Application Configuration (optional)
# APP_VERBOSE_LEVEL: "warn", "info", or "debug" (leave empty to use default "warn")
# If empty, can be overridden with -v flags: -v (info), -vv (debug)
APP_VERBOSE_LEVEL=
APP_DEBUG=false
# Disable tag deletion operations (safety feature to prevent accidental deletions)
DISABLE_TAG_DELETION=false
# Show total registry usage chart on the explore page
SHOW_TOTAL_USAGE=false

# Server Configuration (optional)
SERVER_HOST=localhost
SERVER_PORT=3000
SERVER_DEBUG=false

# Frontend debug tooling (optional)
# Set to 1 to enable the Vite bundle visualizer during builds.
FRONTEND_DEBUG=0

# Database Configuration (optional)
DATABASE_CONNECTION=sqlite
DATABASE_URL=data/ui.db
DATABASE_SHOW_SQL=false

# Scraper Configuration (optional)
# Ex. 30s, 1m, 1h
# When 0 it disables scheduled syncs. `start` still performs the initial sync,
# and manual sync remains available.
SCRAPER_SYNC_INTERVAL=1h
# How many concurrent workers to scrape tags
SCRAPER_WORKERS=20
# Used to control how many workers per registry.
# 0 means it is automatically allocate workers per registry
# Ex. 20 workers / 5 registries = 4 worker per registry
SCRAPER_MAX_PER_REGISTRY=0
# When running a scraper standalone you can see a progress bar instead of having text showing up
SCRAPER_SHOW_PROGRESS=false
SCRAPER_DEBUG=false
# How many tags should fail before it should stop continuing for a registry
SCRAPER_CIRCUIT_BREAKER_THRESHOLD=5
# Maximum number of HTTP retries for failed requests
SCRAPER_HTTP_MAX_RETRIES=2


# Registry Configuration (Dynamic)
# Default registry
REGISTRY_URL=https://registry.example.com
REGISTRY_AUTH=base64(username:password)

# Named registries (use any suffix)
REGISTRY_URL_GH=https://ghcr.io
REGISTRY_AUTH_GH=base64(github_org:github_token)
REGISTRY_SETTINGS_GH_ORG=true

REGISTRY_URL_DOCKER=https://registry-1.docker.io
REGISTRY_AUTH_DOCKER=base64(docker_user:docker_token)
